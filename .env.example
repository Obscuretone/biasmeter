MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed
REQUEST_TIMEOUT_SECONDS=20
REPORT_PATH=reports/latest.html
