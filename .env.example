MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed
REQUEST_TIMEOUT_SECONDS=20
REPORT_PATH=reports/latest.html
DOCUMENT_DB_PATH=data/biasmeter.sqlite
TOPIC_MATCH_THRESHOLD=0.82
EMBEDDING_BATCH_SIZE=16
MISTRAL_MAX_RETRIES=5
MISTRAL_RETRY_BASE_SECONDS=5
MISTRAL_RETRY_MAX_SLEEP_SECONDS=120
MISTRAL_MIN_REQUEST_INTERVAL_SECONDS=1
